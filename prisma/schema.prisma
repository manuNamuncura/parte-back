generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Obra {
  id          String   @id @default(cuid())
  nombre      String
  cliente     String
  direccion   String
  fechaInicio DateTime
  fechaFin    DateTime?

  partes      ParteDiario[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("obras")
}

model ParteDiario {
  id          String   @id @default(cuid())
  fecha       DateTime @default(now())
  descripcion String
  horas       Int
  estado      String   // NORMAL | RETRASO | INCIDENTE

  obraId      String
  obra        Obra     @relation(fields: [obraId], references: [id])

  createdAt   DateTime @default(now())

  @@map("partes_diarios")
}